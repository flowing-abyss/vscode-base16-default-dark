    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#585858"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "support.variable"
            ],
            "settings": {
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Special Variable",
            "scope": [
                "variable.language",
                "variable.other.readwrite.instance",
                "variable.other.object",
                "variable.parameter.function"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#ba8baf"
            }
        },
        {
            "name": "Constant",
            "scope": [
                "constant",
                "support.constant"
            ],
            "settings": {
                "foreground": "#dc9656"
            }
        },
        {
            "name": "Number",
            "scope": [
                "constant.numeric",
                "constant.language.numeric"
            ],
            "settings": {
                "foreground": "#dc9656"
            }
        },
        {
            "name": "Boolean",
            "scope": [
                "constant.language.boolean"
            ],
            "settings": {
                "foreground": "#dc9656"
            }
        },
        {
            "name": "String",
            "scope": [
                "string",
                "string.quoted",
                "string.template"
            ],
            "settings": {
                "foreground": "#a1b56c"
            }
        },
        {
            "name": "String Escape",
            "scope": [
                "constant.character.escape",
                "constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#dc9656"
            }
        },
        {
            "name": "String Regex",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#a1b56c"
            }
        },
        {
            "name": "String Special",
            "scope": [
                "string.other.link",
                "string.other.link.description"
            ],
            "settings": {
                "foreground": "#a1b56c"
            }
        },
        {
            "name": "Function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#7cafc2"
            }
        },
        {
            "name": "Type",
            "scope": [
                "entity.name.type",
                "support.type",
                "storage.type.class",
                "storage.type.interface",
                "storage.type.enum"
            ],
            "settings": {
                "foreground": "#f7ca88"
            }
        },
        {
            "name": "Class",
            "scope": [
                "entity.name.type.class",
                "entity.name.type.struct"
            ],
            "settings": {
                "foreground": "#f7ca88"
            }
        },
        {
            "name": "Tag",
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Attribute",
            "scope": [
                "entity.other.attribute-name",
                "meta.attribute"
            ],
            "settings": {
                "foreground": "#7cafc2"
            }
        },
        {
            "name": "Constructor",
            "scope": [
                "entity.name.function.constructor",
                "support.function.constructor"
            ],
            "settings": {
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "punctuation.definition",
                "punctuation.section",
                "punctuation.separator",
                "punctuation.terminator",
                "punctuation.definition.string",
                "punctuation.definition.variable",
                "punctuation.definition.parameters",
                "punctuation.definition.array",
                "punctuation.definition.list"
            ],
            "settings": {
                "foreground": "#d8d8d8"
            }
        },
        {
            "name": "Operator",
            "scope": [
                "keyword.operator",
                "keyword.control.new",
                "keyword.control.conditional"
            ],
            "settings": {
                "foreground": "#d8d8d8"
            }
        },
        {
            "name": "Title",
            "scope": [
                "entity.name.section",
                "markup.heading",
                "markup.heading.setext"
            ],
            "settings": {
                "foreground": "#f7ca88"
            }
        },
        {
            "name": "Label",
            "scope": [
                "entity.name.label"
            ],
            "settings": {
                "foreground": "#f7ca88"
            }
        },
        {
            "name": "Link",
            "scope": [
                "markup.underline.link",
                "string.other.link.title"
            ],
            "settings": {
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Emphasis",
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Strong",
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Text Literal",
            "scope": [
                "text.literal",
                "markup.raw"
            ],
            "settings": {
                "foreground": "#a1b56c"
            }
        },
        {
            "name": "Diff Add",
            "scope": [
                "markup.inserted"
            ],
            "settings": {
                "foreground": "#a1b56c"
            }
        },
        {
            "name": "Diff Delete",
            "scope": [
                "markup.deleted"
            ],
            "settings": {
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Diff Change",
            "scope": [
                "markup.changed"
            ],
            "settings": {
                "foreground": "#f7ca88"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#ab4642"
            }
        },
        {
            "name": "Deprecated",
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#f7ca88"
            }
        }
    ]
}
